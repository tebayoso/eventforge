{
  "name": "EventBridge",
  "version": "0.1.0",
  "status": "local-ready-hosted-gated",
  "description": "Client bootstrap manifest for EventBridge's policy-gated MCP tools. The EventForge package and command remain stable for compatibility.",
  "transports": [
    {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "--package", "github:tebayoso/eventforge", "eventforge-mcp"],
      "environment": {
        "EVENTFORGE_CODEX_WORKDIR": "<absolute-project-path>"
      },
      "authentication": "none-local"
    },
    {
      "type": "streamable-http",
      "url": "http://127.0.0.1:4312/mcp",
      "authentication": "optional-loopback-bearer",
      "launcher": "npx -y --package github:tebayoso/eventforge eventforge-mcp-http"
    }
  ],
  "hosted": {
    "url": "https://api.eventforge.dev/mcp",
    "status": "gated",
    "authentication": "oauth-2.1-when-enabled",
    "documentation": "https://github.com/tebayoso/eventforge/blob/main/workfiles/CONFIGURATION.md#remote-streamable-http"
  }
}
