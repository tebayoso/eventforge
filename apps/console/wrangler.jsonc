{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "eventforge-console",
  "compatibility_date": "2026-07-17",
  "workers_dev": false,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "eventforge.dev",
      "custom_domain": true
    }
  ]
}
