# Required to run Codex-backed agent jobs. Keep this outside source control.
OPENAI_API_KEY=

# Control plane
PORT=4310
DATABASE_URL=postgres://eventforge:eventforge@localhost:5432/eventforge
EVENTFORGE_PUBLIC_URL=http://localhost:4310
EVENTFORGE_MASTER_KEY=replace-with-32-or-more-random-bytes

# Enable deterministic demo provider events without provider credentials.
EVENTFORGE_DEMO_MODE=true

# Provider verification / OAuth. Live routes reject unsigned events when their secret is set.
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
# Local GitHub development (created automatically by `pnpm dev:github`).
# The Smee channel is a disposable public relay; do not use it in production.
EVENTFORGE_GITHUB_LOCAL_WEBHOOK=false
EVENTFORGE_GITHUB_REPOSITORY=
EVENTFORGE_GITHUB_RELAY_URL=
EVENTFORGE_LOCAL_WEBHOOK_TARGET=http://127.0.0.1:4310/webhooks/github
LINEAR_WEBHOOK_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
SENTRY_WEBHOOK_SECRET=
SENTRY_AUTH_TOKEN=

# Optional artifact storage (Docker Compose provides MinIO defaults).
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=eventforge-artifacts
S3_ACCESS_KEY=eventforge
S3_SECRET_KEY=eventforge-secret
