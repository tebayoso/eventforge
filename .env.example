# Required to run Codex-backed agent jobs. Keep this outside source control.
OPENAI_API_KEY=

# Control plane
PORT=4310
DATABASE_URL=postgres://eventforge:eventforge@localhost:5432/eventforge
EVENTFORGE_PUBLIC_URL=http://localhost:4310
EVENTFORGE_MASTER_KEY=replace-with-32-or-more-random-bytes
# Comma-separated browser origins. This must be explicitly set in production.
EVENTFORGE_ALLOWED_ORIGINS=http://localhost:5173

# Enable deterministic demo provider events without provider credentials.
EVENTFORGE_DEMO_MODE=true
# Local GitHub mode starts actual read-only Codex SDK review threads by default.
EVENTFORGE_RUNNER=codex
EVENTFORGE_CODEX_WORKDIR=

# Provider verification / OAuth. Live routes reject unsigned events when their secret is set.
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
# Local GitHub development (created automatically by `pnpm dev:github`).
# Cloudflare Quick Tunnels are temporary and receive a new public URL on every launch.
EVENTFORGE_GITHUB_LOCAL_WEBHOOK=false
EVENTFORGE_GITHUB_REPOSITORY=
EVENTFORGE_CLOUDFLARED_BIN=cloudflared
# Empty by default: EventForge uses the OS null device to avoid inheriting another tunnel's config.
EVENTFORGE_CLOUDFLARED_CONFIG=
EVENTFORGE_LOCAL_TUNNEL_ORIGIN=http://127.0.0.1:4310
# A remotely managed production tunnel token. Keep this in a secret store, never in source control.
CLOUDFLARE_TUNNEL_TOKEN=
LINEAR_WEBHOOK_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
SENTRY_WEBHOOK_SECRET=
SENTRY_AUTH_TOKEN=

# Optional artifact storage (Docker Compose provides MinIO defaults).
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=eventforge-artifacts
S3_ACCESS_KEY=eventforge
S3_SECRET_KEY=eventforge-secret
