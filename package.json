{
  "name": "eventforge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @eventforge/control-plane dev",
    "dev:github": "pnpm --filter @eventforge/control-plane start:github",
    "dev:console": "pnpm --filter @eventforge/console dev",
    "dev:desktop": "pnpm --filter @eventforge/desktop dev",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
